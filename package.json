{
  "name": "react-native-responsive-rn",
  "version": "0.1.1",
  "description": "Minimal responsive utility for React Native using breakpoint-based values (r + t).",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "packageManager": "npm@11.6.2",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "npm run --prefix example start",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "npx tsc",
    "lint": "eslint \"**/*.{js,ts}\" --fix",
    "test": "jest",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "responsive",
    "breakpoints",
    "ui",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somnathnath8482/react-native-responsive-rn.git"
  },
  "author": "Somnath nath <somnathnath8482@gmail.com> (https://github.com/somnathnath8482)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/somnathnath8482/react-native-responsive-rn/issues"
  },
  "homepage": "https://github.com/somnathnath8482/react-native-responsive-rn#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.0.0",
    "@jest/globals": "^30.0.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/react": "^19.2.0",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^19.2.4",
    "turbo": "^2.9.9",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "dependencies": {
    "eslint-plugin-ft-flow": "^3.0.11"
  }
}
